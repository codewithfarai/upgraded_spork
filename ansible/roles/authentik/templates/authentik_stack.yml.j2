version: '3.8'

services:
  # ==========================================================================
  # PostgreSQL HA Cluster (Zalando Spilo - Patroni + HAProxy + etcd)
  # ==========================================================================
  etcd:
    image: quay.io/coreos/etcd:v3.5.11
    environment:
      ETCD_UNSUPPORTED_ARCH: arm64
      ETCD_LISTEN_CLIENT_URLS: http://0.0.0.0:2379
      ETCD_ADVERTISE_CLIENT_URLS: http://authentik_etcd:2379
      ETCD_ENABLE_V2: "true"
    networks:
      - authentik-backend
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-1

  pg-0:
    image: ghcr.io/zalando/spilo-16:3.3-p3
    environment:
      SCOPE: authentik
      ETCD_HOST: authentik_etcd:2379
      POSTGRES_PASSWORD_FILE: "/run/secrets/authentik_db_password"
      PGPASSWORD_SUPERUSER_FILE: "/run/secrets/authentik_db_password"
      SPILO_CONFIGURATION: |
        superuser: postgres
        admin_role: admin
        bootstrap:
          dcs:
            ttl: 30
            loop_wait: 10
            retry_timeout: 10
            maximum_lag_on_failover: 1048576
          initdb:
            - auth-host: md5
            - auth-local: trust
            - encoding: UTF8
            - data-checksums
          users:
            authentik:
              password: "{{ authentik_db_password }}"
              options: [createdb, createrole]
            standby:
              password: "{{ authentik_db_password }}"
              options: [replication]
          databases:
            authentik: authentik
        postgresql:
          use_pg_rewind: true
          parameters:
            listen_addresses: '*'
          pg_hba:
            - local all all trust
            - host all all 0.0.0.0/0 md5
            - host replication all 0.0.0.0/0 md5
    volumes:
      - authentik-postgres-0:/home/postgres/pgdata
    networks:
      - authentik-backend
    secrets:
      - source: authentik_db_password-{{ authentik_db_password_hash }}
        target: authentik_db_password
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-1

  pg-1:
    image: ghcr.io/zalando/spilo-16:3.3-p3
    environment:
      SCOPE: authentik
      ETCD_HOST: authentik_etcd:2379
      POSTGRES_PASSWORD_FILE: "/run/secrets/authentik_db_password"
      PGPASSWORD_SUPERUSER_FILE: "/run/secrets/authentik_db_password"
      SPILO_CONFIGURATION: |
        superuser: postgres
        admin_role: admin
        bootstrap:
          dcs:
            ttl: 30
            loop_wait: 10
            retry_timeout: 10
            maximum_lag_on_failover: 1048576
          initdb:
            - auth-host: md5
            - auth-local: trust
            - encoding: UTF8
            - data-checksums
          users:
            authentik:
              password: "{{ authentik_db_password }}"
              options: [createdb, createrole]
            standby:
              password: "{{ authentik_db_password }}"
              options: [replication]
          databases:
            authentik: authentik
        postgresql:
          use_pg_rewind: true
          parameters:
            listen_addresses: '*'
          pg_hba:
            - local all all trust
            - host all all 0.0.0.0/0 md5
            - host replication all 0.0.0.0/0 md5
    volumes:
      - authentik-postgres-1:/home/postgres/pgdata
    networks:
      - authentik-backend
    secrets:
      - source: authentik_db_password-{{ authentik_db_password_hash }}
        target: authentik_db_password
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-2

  pgpool:
    image: haproxy:2.8-alpine
    command: |
      sh -c 'cat <<EOF > /tmp/haproxy.cfg
      global
        maxconn 100
      defaults
        log global
        mode tcp
        retries 2
        timeout client 30m
        timeout connect 4s
        timeout server 30m
        timeout check 5s
      listen postgres
        bind *:5432
        option httpchk GET /primary
        http-check expect status 200
        default-server inter 3s fall 3 rise 2 on-marked-down shutdown-sessions init-addr last,libc,none
        server pg-0 tasks.authentik_pg-0:5432 maxconn 100 check port 8008
        server pg-1 tasks.authentik_pg-1:5432 maxconn 100 check port 8008
      EOF
      haproxy -f /tmp/haproxy.cfg'
    networks:
      - authentik-backend
    deploy:
      replicas: 2
      placement:
        constraints:
          - node.labels.role == database

  redis-primary:
    image: redis:7-alpine
    command: |
      sh -c 'redis-server --save 60 1 --loglevel warning'
    volumes:
      - authentik-redis-0:/data
    networks:
      - authentik-backend
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-1

  redis-replica:
    image: redis:7-alpine
    command: |
      sh -c 'redis-server --replicaof authentik_redis-primary 6379 --save 60 1 --loglevel warning'
    volumes:
      - authentik-redis-1:/data
    networks:
      - authentik-backend
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-2

  redis-sentinel:
    image: redis:7-alpine
    command: |
      sh -c 'echo "port 26379" > /tmp/sentinel.conf &&
      echo "dir /tmp" >> /tmp/sentinel.conf &&
      echo "sentinel monitor mymaster authentik_redis-primary 6379 2" >> /tmp/sentinel.conf &&
      echo "sentinel down-after-milliseconds mymaster 5000" >> /tmp/sentinel.conf &&
      echo "sentinel failover-timeout mymaster 10000" >> /tmp/sentinel.conf &&
      echo "sentinel parallel-syncs mymaster 1" >> /tmp/sentinel.conf &&
      echo "sentinel resolve-hostnames yes" >> /tmp/sentinel.conf &&
      echo "sentinel announce-hostnames yes" >> /tmp/sentinel.conf &&
      redis-sentinel /tmp/sentinel.conf'
    networks:
      - authentik-backend
    deploy:
      replicas: 3
      placement:
        constraints:
          - node.labels.role == worker
        preferences:
          - spread: node.id

  server:
    image: ghcr.io/goauthentik/server:{{ authentik_version | default('2026.2.1') }}
    command: server
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
      - /app/lifecycle
    environment:
      AUTHENTIK_SECRET_KEY: "file:///run/secrets/authentik_secret_key"
      AUTHENTIK_REDIS__HOST: authentik_redis-primary
      AUTHENTIK_POSTGRESQL__HOST: authentik_pgpool
      AUTHENTIK_POSTGRESQL__USER: authentik
      AUTHENTIK_POSTGRESQL__NAME: authentik
      AUTHENTIK_POSTGRESQL__PASSWORD: "file:///run/secrets/authentik_db_password"
      AUTHENTIK_BOOTSTRAP_PASSWORD: "file:///run/secrets/authentik_admin_password"
      AUTHENTIK_BOOTSTRAP_TOKEN: "file:///run/secrets/authentik_bootstrap_token"
      AUTHENTIK_BOOTSTRAP_EMAIL: "file:///run/secrets/authentik_admin_email"
    networks:
      - traefik-public
      - authentik-backend
    ports:
      - "9000:9000"
    secrets:
      - source: authentik_secret_key-{{ authentik_secret_key_hash }}
        target: authentik_secret_key
      - source: authentik_db_password-{{ authentik_db_password_hash }}
        target: authentik_db_password
      - source: authentik_admin_password-{{ authentik_admin_password_hash }}
        target: authentik_admin_password
      - source: authentik_bootstrap_token-{{ authentik_bootstrap_token_hash }}
        target: authentik_bootstrap_token
      - source: authentik_admin_email-{{ authentik_admin_email_hash }}
        target: authentik_admin_email
    deploy:
      mode: replicated
      replicas: {{ authentik_server_replicas | default(2) }}
      placement:
        constraints:
          - node.labels.role == worker
        preferences:
          - spread: node.id
      labels:
        - traefik.enable=true
        - traefik.http.routers.authentik.rule=Host(`{{ authentik_full_domain }}`)
        - traefik.http.routers.authentik.entrypoints=web
        - traefik.http.routers.authentik.service=authentik-svc
        - traefik.http.services.authentik-svc.loadbalancer.server.port=9000
        - traefik.http.routers.authentik-outpost.rule=HostRegexp(`{host:.+}`) && PathPrefix(`/outpost.goauthentik.io/`)
        - traefik.http.routers.authentik-outpost.entrypoints=web
        - traefik.http.routers.authentik-outpost.service=authentik-svc
        - traefik.http.routers.authentik-outpost.priority=15

  worker:
    image: ghcr.io/goauthentik/server:{{ authentik_version | default('2026.2.1') }}
    command: worker
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
      - /app/lifecycle
    environment:
      AUTHENTIK_SECRET_KEY: "file:///run/secrets/authentik_secret_key"
      AUTHENTIK_REDIS__HOST: authentik_redis-primary
      AUTHENTIK_POSTGRESQL__HOST: authentik_pgpool
      AUTHENTIK_POSTGRESQL__USER: authentik
      AUTHENTIK_POSTGRESQL__NAME: authentik
      AUTHENTIK_POSTGRESQL__PASSWORD: "file:///run/secrets/authentik_db_password"
    networks:
      - authentik-backend
    secrets:
      - source: authentik_secret_key-{{ authentik_secret_key_hash }}
        target: authentik_secret_key
      - source: authentik_db_password-{{ authentik_db_password_hash }}
        target: authentik_db_password
    deploy:
      mode: replicated
      replicas: {{ authentik_worker_replicas | default(2) }}
      placement:
        constraints:
          - node.labels.role == worker
        preferences:
          - spread: node.id

volumes:
  authentik-postgres-0:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/authentik/postgres-0
  authentik-postgres-1:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/authentik/postgres-1
  authentik-redis-0:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/authentik/redis-0
  authentik-redis-1:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/authentik/redis-1

networks:
  traefik-public:
    external: true
  authentik-backend:
    driver: overlay
    internal: true
    driver_opts:
      encrypted: "true"

secrets:
  authentik_secret_key-{{ authentik_secret_key_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_secret_key
  authentik_db_password-{{ authentik_db_password_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_db_password
  authentik_admin_password-{{ authentik_admin_password_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_admin_password
  authentik_bootstrap_token-{{ authentik_bootstrap_token_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_bootstrap_token
  authentik_admin_email-{{ authentik_admin_email_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_admin_email
