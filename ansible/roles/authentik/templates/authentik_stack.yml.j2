version: '3.8'

services:
  server:
    image: ghcr.io/goauthentik/server:{{ authentik_version | default('2026.2.1') }}
    command: server
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
      - /app/lifecycle
    environment:
      AUTHENTIK_SECRET_KEY: "file:///run/secrets/authentik_secret_key"
      # Route to the HAProxy instance deployed by database_ha stack
      AUTHENTIK_REDIS__HOST: db_ha_pgpool
      AUTHENTIK_POSTGRESQL__HOST: db_ha_pgpool
      AUTHENTIK_POSTGRESQL__USER: authentik
      AUTHENTIK_POSTGRESQL__NAME: authentik
      AUTHENTIK_POSTGRESQL__PASSWORD: "file:///run/secrets/authentik_db_password"
      AUTHENTIK_POSTGRESQL__SSLMODE: prefer
      AUTHENTIK_POSTGRESQL__CONN_MAX_AGE: 0
      AUTHENTIK_POSTGRESQL__DISABLE_SERVER_SIDE_CURSORS: "true"
      # CSRF fix for Hetzner LB SSL termination
      AUTHENTIK_CSRF_TRUSTED_ORIGINS: "https://{{ authentik_full_domain }}"
      AUTHENTIK_BOOTSTRAP_PASSWORD: "file:///run/secrets/authentik_admin_password"
      AUTHENTIK_BOOTSTRAP_TOKEN: "file:///run/secrets/authentik_bootstrap_token"
      AUTHENTIK_BOOTSTRAP_EMAIL: "file:///run/secrets/authentik_admin_email"
    networks:
      - traefik-public
      - shared-backend
    ports:
      - "9000:9000"
    secrets:
      - source: authentik_secret_key-{{ authentik_secret_key_hash }}
        target: authentik_secret_key
      - source: authentik_admin_password-{{ authentik_admin_password_hash }}
        target: authentik_admin_password
      - source: authentik_bootstrap_token-{{ authentik_bootstrap_token_hash }}
        target: authentik_bootstrap_token
      - source: authentik_admin_email-{{ authentik_admin_email_hash }}
        target: authentik_admin_email
      - authentik_db_password
    deploy:
      mode: replicated
      replicas: {{ authentik_server_replicas | default(2) }}
      placement:
        constraints:
          - node.labels.role == worker
        preferences:
          - spread: node.id
      labels:
        - traefik.enable=true
        - traefik.http.routers.authentik.rule=Host(`{{ authentik_full_domain }}`)
        - traefik.http.routers.authentik.entrypoints=web
        - traefik.http.routers.authentik.service=authentik-svc
        - traefik.http.services.authentik-svc.loadbalancer.server.port=9000
        - traefik.http.routers.authentik-outpost.rule=HostRegexp(`{host:.+}`) && PathPrefix(`/outpost.goauthentik.io/`)
        - traefik.http.routers.authentik-outpost.entrypoints=web
        - traefik.http.routers.authentik-outpost.service=authentik-svc
        - traefik.http.routers.authentik-outpost.priority=15
        - traefik.swarm.network=traefik-public

  worker:
    image: ghcr.io/goauthentik/server:{{ authentik_version | default('2026.2.1') }}
    command: worker
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
      - /app/lifecycle
    environment:
      AUTHENTIK_SECRET_KEY: "file:///run/secrets/authentik_secret_key"
      AUTHENTIK_REDIS__HOST: db_ha_pgpool
      AUTHENTIK_POSTGRESQL__HOST: db_ha_pgpool
      AUTHENTIK_POSTGRESQL__USER: authentik
      AUTHENTIK_POSTGRESQL__NAME: authentik
      AUTHENTIK_POSTGRESQL__PASSWORD: "file:///run/secrets/authentik_db_password"
      AUTHENTIK_POSTGRESQL__SSLMODE: prefer
      AUTHENTIK_POSTGRESQL__CONN_MAX_AGE: 0
      AUTHENTIK_POSTGRESQL__DISABLE_SERVER_SIDE_CURSORS: "true"
    networks:
      - shared-backend
    secrets:
      - source: authentik_secret_key-{{ authentik_secret_key_hash }}
        target: authentik_secret_key
      - authentik_db_password
    deploy:
      mode: replicated
      replicas: {{ authentik_worker_replicas | default(2) }}
      placement:
        constraints:
          - node.labels.role == worker
        preferences:
          - spread: node.id

networks:
  traefik-public:
    external: true
  shared-backend:
    external: true

secrets:
  authentik_secret_key-{{ authentik_secret_key_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_secret_key
  authentik_admin_password-{{ authentik_admin_password_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_admin_password
  authentik_bootstrap_token-{{ authentik_bootstrap_token_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_bootstrap_token
  authentik_admin_email-{{ authentik_admin_email_hash }}:
    file: /opt/docker/stacks/authentik/secrets/authentik_admin_email

  authentik_db_password:
    external: true
    # FIXED: Swarm prepends the creating stack's name ("db_ha_") to the secret!
    name: "db_ha_authentik_db_password-{{ authentik_db_password_hash }}"
