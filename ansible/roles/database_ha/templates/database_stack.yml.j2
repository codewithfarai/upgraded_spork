version: '3.8'

# Gather the database nodes from Ansible inventory (dynamically handles 2 or 3 nodes)
{% set db_nodes = groups['database'] %}
{% set db_count = db_nodes | length %}

# Build etcd cluster connection strings dynamically
{% set etcd_cluster_list = [] %}
{% set etcd_client_list = [] %}
{% for host in db_nodes %}
{% set _ = etcd_cluster_list.append('etcd-' ~ loop.index0 ~ '=http://etcd-' ~ loop.index0 ~ ':2380') %}
{% set _ = etcd_client_list.append('etcd-' ~ loop.index0 ~ ':2379') %}
{% endfor %}
{% set etcd_initial_cluster = etcd_cluster_list | join(',') %}
{% set etcd_client_hosts = etcd_client_list | join(',') %}

services:

{% for db_host in db_nodes %}
  # ==========================================================================
  # Node {{ loop.index0 }} Services (Matches Terraform Hostnames)
  # ==========================================================================

  etcd-{{ loop.index0 }}:
    image: quay.io/coreos/etcd:v3.5.11
    environment:
      ETCD_UNSUPPORTED_ARCH: arm64
      ETCD_NAME: etcd-{{ loop.index0 }}
      ETCD_LISTEN_CLIENT_URLS: http://0.0.0.0:2379
      ETCD_ADVERTISE_CLIENT_URLS: http://etcd-{{ loop.index0 }}:2379
      ETCD_LISTEN_PEER_URLS: http://0.0.0.0:2380
      ETCD_INITIAL_ADVERTISE_PEER_URLS: http://etcd-{{ loop.index0 }}:2380
      ETCD_INITIAL_CLUSTER: "{{ etcd_initial_cluster }}"
      ETCD_INITIAL_CLUSTER_STATE: new
      ETCD_INITIAL_CLUSTER_TOKEN: pg-ha-cluster
      ETCD_ENABLE_V2: "true"
      ETCD_LISTEN_METRICS_URLS: http://0.0.0.0:2381
      ETCD_DATA_DIR: /etcd-data
    volumes:
      - etcd-{{ loop.index0 }}:/etcd-data
    networks:
      - shared-backend
    deploy:
      replicas: 1
      placement:
        constraints:
          # Matches standard terraform hostname format: upgraded-spork-db-dev-1
          - node.hostname == upgraded-spork-db-{{ target_env }}-{{ loop.index0 + 1 }}

  pg-{{ loop.index0 }}:
    image: ghcr.io/zalando/spilo-16:3.3-p3
    environment:
      SCOPE: authentik
      PATRONI_NAME: "{{ target_env }}-pg-{{ loop.index0 }}"
      ETCD_HOST: "etcd-{{ loop.index0 }}:2379"
      POSTGRES_PASSWORD_FILE: "/run/secrets/authentik_db_password"
      PGPASSWORD_SUPERUSER_FILE: "/run/secrets/authentik_db_password"
      PATRONI_REPLICATION_USERNAME: standby
      PATRONI_REPLICATION_PASSWORD: "{{ authentik_db_password }}"
      PATRONI_REPLICATION_ADDRESS: "0.0.0.0/0"
      SPILO_CONFIGURATION: |
        superuser: postgres
        admin_role: admin
        bootstrap:
          dcs:
            ttl: 30
            loop_wait: 10
            retry_timeout: 10
            maximum_lag_on_failover: 1048576
          initdb:
            - auth-host: md5
            - auth-local: trust
            - encoding: UTF8
            - data-checksums
          users:
            authentik:
              password: "{{ authentik_db_password }}"
              options: [createdb, createrole]
            standby:
              password: "{{ authentik_db_password }}"
              options: [replication]
          databases:
            authentik: authentik
        postgresql:
          use_pg_rewind: true
          parameters:
            listen_addresses: '*'
            ssl: 'on'
          pg_hba:
            - local all all trust
            - hostssl all all 0.0.0.0/0 md5
            - host replication standby 0.0.0.0/0 md5
            - local replication standby trust
    volumes:
      - postgres-{{ loop.index0 }}:/home/postgres/pgdata
    networks:
      - shared-backend
    secrets:
      - source: authentik_db_password-{{ authentik_db_password_hash }}
        target: authentik_db_password
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-{{ loop.index0 + 1 }}

  redis-{{ loop.index0 }}:
    image: redis:7-alpine
    command: sh -c 'redis-server --requirepass "$$(cat /run/secrets/redis_password)" --masterauth "$$(cat /run/secrets/redis_password)" --replica-announce-ip redis-{{ loop.index0 }} {% if loop.index0 > 0 %}--replicaof redis-0 6379 {% endif %}--save 60 1 --loglevel debug --maxmemory 512mb --maxmemory-policy allkeys-lru'
    volumes:
      - redis-{{ loop.index0 }}:/data
    networks:
      - shared-backend
    secrets:
      - source: redis_password-{{ redis_password_hash }}
        target: redis_password
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-{{ loop.index0 + 1 }}

  rabbitmq-{{ loop.index0 }}:
    image: rabbitmq:4.1-management
    environment:
      RABBITMQ_NODENAME: rabbit@rabbitmq-{{ loop.index0 }}
      RABBITMQ_ERLANG_COOKIE: "ZPBCHXWQQNFXIKYXWJLZ"
    volumes:
      - rabbitmq-{{ loop.index0 }}:/var/lib/rabbitmq
    configs:
      - source: rabbitmq_config-{{ rabbitmq_config_hash }}
        target: /etc/rabbitmq/rabbitmq.conf
      - source: rabbitmq_plugins-{{ rabbitmq_plugins_hash }}
        target: /etc/rabbitmq/enabled_plugins
    networks:
      - shared-backend
      - traefik-public
    secrets:
      - source: rabbitmq_password-{{ rabbitmq_password_hash }}
        target: rabbitmq_password
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-{{ loop.index0 + 1 }}
      labels:
        - traefik.enable=true
        - traefik.http.routers.rabbitmq.rule=Host(`rabbitmq.{{ target_env + '.' if target_env != 'prod' else '' }}{{ domain_name }}`)
        - traefik.http.routers.rabbitmq.entrypoints=web
        - traefik.http.routers.rabbitmq.service=rabbitmq-svc
        - traefik.http.routers.rabbitmq.middlewares=authentik-forwardauth@file
        - traefik.http.services.rabbitmq-svc.loadbalancer.server.port=15672
        - traefik.http.services.rabbitmq-svc.loadbalancer.sticky.cookie=true
        - traefik.http.services.rabbitmq-svc.loadbalancer.sticky.cookie.name=rabbitmq-sess
        - traefik.swarm.network=traefik-public

  postgres-exporter-{{ loop.index0 }}:
    image: prometheuscommunity/postgres-exporter
    environment:
      DATA_SOURCE_NAME: "postgresql://authentik:{{ authentik_db_password | urlencode }}@pg-{{ loop.index0 }}:5432/authentik?sslmode=require"
    networks:
      - shared-backend
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-{{ loop.index0 + 1 }}

  redis-exporter-{{ loop.index0 }}:
    image: oliver006/redis_exporter
    environment:
      REDIS_ADDR: "redis-{{ loop.index0 }}:6379"
      REDIS_PASSWORD: "{{ effective_redis_password }}"
    networks:
      - shared-backend
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.hostname == upgraded-spork-db-{{ target_env }}-{{ loop.index0 + 1 }}
{% endfor %}
  # ==========================================================================
  # Dynamic Routing & Monitors
  # ==========================================================================
  pgpool:
    image: haproxy:2.8-alpine
    environment:
      HAPROXY_CFG: |
        global
          maxconn 1000
          log stdout format raw local0 info

        resolvers docker
          nameserver dns 127.0.0.11:53
          resolve_retries 3
          timeout resolve 1s
          timeout retry   1s
          hold valid      10s

        frontend stats
          bind *:8404
          mode http
          http-request use-service prometheus-exporter if { path /metrics }
          stats enable
          stats uri /stats
          stats refresh 10s

        defaults
          log global
          mode tcp
          retries 2
          timeout client 30m
          timeout connect 4s
          timeout server 30m
          timeout check 5s

        listen postgres
          bind *:5432
          mode tcp
          option httpchk
          http-check send meth HEAD uri /master ver HTTP/1.1 hdr Host pgpool
          http-check expect status 200
          default-server inter 3s fall 3 rise 2 on-marked-down shutdown-sessions init-addr libc,none
          {% for host in db_nodes %}
          server pg-{{ loop.index0 }} pg-{{ loop.index0 }}:5432 maxconn 100 check port 8008 resolvers docker resolve-prefer ipv4
          {% endfor %}

        listen redis
          bind *:6379
          option tcp-check
          tcp-check send AUTH\ {{ effective_redis_password }}\r\n
          tcp-check expect string +OK
          tcp-check send PING\r\n
          tcp-check expect string +PONG
          tcp-check send info\ replication\r\n
          tcp-check expect string role:master
          tcp-check send QUIT\r\n
          tcp-check expect string +OK
          default-server inter 3s fall 3 rise 2 on-marked-down shutdown-sessions init-addr libc,none
          {% for host in db_nodes %}
          server redis-{{ loop.index0 }} redis-{{ loop.index0 }}:6379 check resolvers docker resolve-prefer ipv4
          {% endfor %}

        listen rabbitmq-amqp
          bind *:5672
          mode tcp
          balance leastconn
          default-server inter 5s fall 3 rise 2 on-marked-down shutdown-sessions init-addr libc,none
          {% for host in db_nodes %}
          server rabbitmq-{{ loop.index0 }} rabbitmq-{{ loop.index0 }}:5672 check resolvers docker resolve-prefer ipv4
          {% endfor %}

        listen rabbitmq-mqtt
          bind *:1883
          mode tcp
          balance leastconn
          default-server inter 5s fall 3 rise 2 on-marked-down shutdown-sessions init-addr libc,none
          {% for host in db_nodes %}
          server rabbitmq-{{ loop.index0 }} rabbitmq-{{ loop.index0 }}:1883 check resolvers docker resolve-prefer ipv4
          {% endfor %}
    # We use $$ to escape the variable so Compose passes it directly to the container's shell
    command: sh -c 'echo "$$HAPROXY_CFG" > /tmp/haproxy.cfg && exec haproxy -W -db -f /tmp/haproxy.cfg'
    networks:
      - shared-backend
      - traefik-public
    deploy:
      replicas: 2
      placement:
        constraints:
          - node.labels.role == database

  redis-sentinel:
    image: redis:7-alpine
    command: >
      sh -c '
      echo "bind 0.0.0.0" > /tmp/sentinel.conf &&
      echo "port 26379" >> /tmp/sentinel.conf &&
      echo "sentinel resolve-hostnames yes" >> /tmp/sentinel.conf &&
      echo "sentinel announce-hostnames yes" >> /tmp/sentinel.conf &&
      echo "sentinel monitor mymaster redis-0 6379 2" >> /tmp/sentinel.conf &&
      echo "sentinel auth-pass mymaster $$(cat /run/secrets/redis_password)" >> /tmp/sentinel.conf &&
      echo "sentinel down-after-milliseconds mymaster 5000" >> /tmp/sentinel.conf &&
      echo "sentinel failover-timeout mymaster 10000" >> /tmp/sentinel.conf &&
      echo "sentinel parallel-syncs mymaster 1" >> /tmp/sentinel.conf &&
      exec redis-server /tmp/sentinel.conf --sentinel
      '
    networks:
      - shared-backend
    secrets:
      - source: redis_password-{{ redis_password_hash }}
        target: redis_password
    deploy:
      replicas: 3
      placement:
        preferences:
          - spread: node.id

volumes:
{% for host in db_nodes %}
  postgres-{{ loop.index0 }}:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/database_ha/postgres-{{ loop.index0 }}
  redis-{{ loop.index0 }}:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/database_ha/redis-{{ loop.index0 }}
  rabbitmq-{{ loop.index0 }}:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/database_ha/rabbitmq-{{ loop.index0 }}
  etcd-{{ loop.index0 }}:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/database_ha/etcd-{{ loop.index0 }}
{% endfor %}

networks:
  shared-backend:
    external: true
  traefik-public:
    external: true

secrets:
  authentik_db_password-{{ authentik_db_password_hash }}:
    file: /opt/docker/stacks/database_ha/secrets/authentik_db_password

  redis_password-{{ redis_password_hash }}:
    file: /opt/docker/stacks/database_ha/secrets/redis_password

  rabbitmq_password-{{ rabbitmq_password_hash }}:
    file: /opt/docker/stacks/database_ha/secrets/rabbitmq_password

configs:
  rabbitmq_config-{{ rabbitmq_config_hash }}:
    file: /opt/docker/stacks/database_ha/configs/rabbitmq.conf
  rabbitmq_plugins-{{ rabbitmq_plugins_hash }}:
    file: /opt/docker/stacks/database_ha/configs/enabled_plugins
