version: '3.8'

services:
  admin_service:
    image: {{ admin_service_image }}:{{ admin_service_version }}
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    environment:
      # Authentik OIDC (JWT validation)
      AUTHENTIK_JWKS_URL: "https://{{ authentik_full_domain }}/application/o/ridebase/jwks/"
      AUTHENTIK_ISSUER: "https://{{ authentik_full_domain }}/application/o/ridebase/"
      AUTHENTIK_AUDIENCE: "ridebase"

      # RabbitMQ (via shared-backend overlay load balancer)
      RABBITMQ_URL: "amqp://admin:{{ admin_effective_rabbitmq_password }}@db_ha_pgpool:5672/"
      RABBITMQ_EXCHANGE: "ridebase.events"

      # Database Connection
      DATABASE_URL: "postgresql+asyncpg://{{ admin_service_db_user }}:{{ admin_effective_db_password }}@db_ha_pgpool:5432/{{ admin_service_db_name }}?ssl=require"

      # Authentik API (for syncing group membership)
      AUTHENTIK_API_URL: "https://{{ authentik_full_domain }}"

      # S3 details (Secret key is passed via Secrets)
      S3_ENDPOINT_URL: "{{ admin_service_s3_endpoint_url }}"
      S3_ACCESS_KEY: "{{ admin_service_s3_access_key }}"
      S3_BUCKET_NAME: "{{ admin_service_s3_bucket_name }}"
      S3_REGION_NAME: "{{ admin_service_s3_region_name }}"

    networks:
      - traefik-public
      - shared-backend
    secrets:
      - source: admin_authentik_api_token-{{ admin_authentik_api_token_hash }}
        target: authentik_api_token
      - source: admin_s3_secret_key-{{ admin_s3_secret_key_hash }}
        target: s3_secret_key
      - source: admin_db_password-{{ admin_db_password_hash }}
        target: admin_db_password
    deploy:
      mode: replicated
      replicas: {{ admin_service_replicas | default(2) }}
      placement:
        constraints:
          - node.labels.role == worker
        preferences:
          - spread: node.id
      labels:
        - traefik.enable=true
        - traefik.http.routers.admin_fleet.rule=Host(`{{ admin_service_full_domain }}`)
        - traefik.http.routers.admin_fleet.entrypoints=web
        - traefik.http.routers.admin_fleet.service=admin_service
        - traefik.http.routers.admin_fleet.middlewares=security-headers@file,global-ratelimit@file
        - traefik.http.services.admin_service.loadbalancer.server.port=8000
        - traefik.swarm.network=traefik-public
      update_config:
        parallelism: 1
        delay: 30s
        failure_action: rollback
        order: start-first
      rollback_config:
        parallelism: 1
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.25'
          memory: 128M

networks:
  traefik-public:
    external: true
  shared-backend:
    external: true

secrets:
  admin_authentik_api_token-{{ admin_authentik_api_token_hash }}:
    file: /opt/docker/stacks/admin_service/secrets/authentik_api_token

  admin_s3_secret_key-{{ admin_s3_secret_key_hash }}:
    file: /opt/docker/stacks/admin_service/secrets/s3_secret_key

  admin_db_password-{{ admin_db_password_hash }}:
    file: /opt/docker/stacks/admin_service/secrets/admin_db_password
