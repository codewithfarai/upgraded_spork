{
  "annotations": { "list": [{ "builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": { "custom": {}, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] } }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "footer": { "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true },
      "title": "Successful Login IPs (24h)",
      "targets": [
        { "expr": "sum(count_over_time({job=\"varlogs\"} |= \"Accepted\" | regexp \"Accepted.*from (?P<ip>[^ ]+)\" | ip !~ \"10\\\\..+\" [24h])) by (ip)", "refId": "A" }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "reduce", "options": { "includeTimeField": false, "mode": "reduceRow", "reducers": ["lastNotNull"] } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": false }, "indexByName": { "ip": 0, "Value": 1 }, "renameByName": { "Value": "Hits" } } }
      ],
      "type": "table"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending" },
      "title": "Sudo Command Executions",
      "targets": [
        { "expr": "{job=\"varlogs\"} |= \"sudo:\" |= \"COMMAND=\"", "refId": "A" }
      ],
      "type": "logs"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": false, "sortOrder": "Descending" },
      "title": "Authentik Security Events",
      "targets": [
        { "expr": "{service_name=~\"authentik.*\"} |= \"login_failed\"", "refId": "A" }
      ],
      "type": "logs"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": { "dedupStrategy": "none", "showTime": true, "sortOrder": "Descending" },
      "title": "Fail2Ban Banning Events",
      "targets": [
        { "expr": "{job=\"varlogs\"} |= \"fail2ban.actions\" |= \"Ban\"", "refId": "A" }
      ],
      "type": "logs"
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["security"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Security Overview",
  "uid": "security-overview",
  "version": 1
}
