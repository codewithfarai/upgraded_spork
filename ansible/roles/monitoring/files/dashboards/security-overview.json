  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Failed SSH Logins",
      "targets": [
        {
          "expr": "{job=\"varlogs\"} |= \"Failed password\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Authentik Security Events",
      "targets": [
        {
          "expr": "{service_name=~\"authentik.*\"} |= \"login_failed\"",
          "refId": "A"
        }
      ],
      "type": "logs"
    },
    {
      "datasource": "prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Container Restart Rate (15m)",
      "targets": [
        {
          "expr": "count(changes(container_last_seen{container_label_com_docker_swarm_service_name!=\"\"}[15m]) > 2) by (container_label_com_docker_swarm_service_name)",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    }
  ],
  "schemaVersion": 36,
