global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'cluster', 'service']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  receiver: 'discord'

receivers:
  - name: 'discord'
    discord_configs:
      - webhook_url: "{{ lookup('env', 'MONITORING_DISCORD_WEBHOOK') }}"
        send_resolved: true
        title: '{% raw %}{{ .Status | toUpper }}{% endraw %}: {% raw %}{{ .GroupLabels.alertname }}{% endraw %}'
        message: '{% raw %}{{ range .Alerts }}{{ .Annotations.summary }}\n{{ .Annotations.description }}\n{{ end }}{% endraw %}'
