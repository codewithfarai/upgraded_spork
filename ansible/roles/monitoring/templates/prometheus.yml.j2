global:
  scrape_interval: 15s
  evaluation_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets:
          - alertmanager:9093

rule_files:
  - "/etc/prometheus/alert_rules.yml"

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'traefik'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: traefik_traefik
        action: keep
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:8082
      - source_labels: [__meta_dockerswarm_network_name]
        regex: traefik-public
        action: keep
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance

  - job_name: 'node-exporter'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: monitoring_node-exporter
        action: keep
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:9100
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance

  - job_name: 'cadvisor'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: monitoring_cadvisor
        action: keep
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:8080
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance

  - job_name: 'bastion'
    static_configs:
      - targets: ['{{ bastion_internal_ip | default("10.0.2.5") }}:9100']
    relabel_configs:
      - target_label: instance
        replacement: 'bastion'

  - job_name: 'authentik'
    metrics_path: /metrics
    static_configs:
      - targets: ['authentik_server:9300']

  - job_name: 'rabbitmq'
    metrics_path: /metrics
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_service_name]
        regex: db_ha_rabbitmq-.*
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: shared-backend
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:15692
      - target_label: kubernetes_namespace
        replacement: database
      - target_label: namespace
        replacement: database
      - target_label: rabbitmq_cluster
        replacement: db_ha
      - source_labels: [__meta_dockerswarm_service_name]
        target_label: release

  - job_name: 'postgres-exporter'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: db_ha_postgres-exporter-.*
        action: keep
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: shared-backend
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:9187
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance
      - target_label: kubernetes_namespace
        replacement: database
      - source_labels: [__meta_dockerswarm_service_name]
        target_label: release

  - job_name: 'redis-exporter'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: db_ha_redis-exporter-.*
        action: keep
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: shared-backend
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:9121
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance
      - target_label: kubernetes_namespace
        replacement: database
      - target_label: namespace
        replacement: database
      - source_labels: [__meta_dockerswarm_service_name]
        target_label: release

  - job_name: 'etcd'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: db_ha_etcd-.*
        action: keep
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: shared-backend
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:2381
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance
      - target_label: kubernetes_namespace
        replacement: database
      - source_labels: [__meta_dockerswarm_service_name]
        target_label: release

  - job_name: 'pgpool'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: db_ha_pgpool
        action: keep
      - source_labels: [__meta_dockerswarm_task_desired_state]
        regex: running
        action: keep
      - source_labels: [__meta_dockerswarm_network_name]
        regex: shared-backend
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:8404
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance
        replacement: ${1}:8404
      - target_label: job
        replacement: haproxy
      - target_label: kubernetes_namespace
        replacement: database
      - target_label: release
        replacement: db_ha_pgpool
