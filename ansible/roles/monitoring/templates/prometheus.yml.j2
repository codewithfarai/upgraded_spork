global:
  scrape_interval: 15s
  evaluation_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets:
          - alertmanager:9093

rule_files:
  - "/etc/prometheus/alert_rules.yml"

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'traefik'
    static_configs:
      - targets: ['traefik_traefik:80']

  - job_name: 'node-exporter'
    dns_sd_configs:
    - names:
      - 'tasks.monitoring_node-exporter'
      type: 'A'
      port: 9100

  - job_name: 'cadvisor'
    dns_sd_configs:
    - names:
      - 'tasks.monitoring_cadvisor'
      type: 'A'
      port: 8080

  - job_name: 'authentik'
    metrics_path: /metrics
    static_configs:
      - targets: ['authentik_server:9300']
