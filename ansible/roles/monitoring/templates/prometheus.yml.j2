global:
  scrape_interval: 15s
  evaluation_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets:
          - alertmanager:9093

rule_files:
  - "/etc/prometheus/alert_rules.yml"

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'traefik'
    static_configs:
      - targets: ['traefik_traefik:80']

  - job_name: 'node-exporter'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: monitoring_node-exporter
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:9100
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance

  - job_name: 'cadvisor'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: monitoring_cadvisor
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:8080
      - source_labels: [__meta_dockerswarm_node_hostname]
        target_label: instance

  - job_name: 'bastion'
    static_configs:
      - targets: ['{{ bastion_internal_ip | default("10.0.2.5") }}:9100']
    relabel_configs:
      - target_label: instance
        replacement: 'bastion'

  - job_name: 'authentik'
    metrics_path: /metrics
    static_configs:
      - targets: ['authentik_server:9300']

  - job_name: 'rabbitmq'
    metrics_path: /metrics
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: db_ha_rabbitmq-.*
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:15692

  - job_name: 'postgres'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: db_ha_pg-exporter-.*
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:9187

  - job_name: 'redis'
    dockerswarm_sd_configs:
      - host: http://traefik_socket-proxy:2375
        role: tasks
    relabel_configs:
      - source_labels: [__meta_dockerswarm_service_name]
        regex: db_ha_redis-exporter-.*
        action: keep
      - source_labels: [__address__]
        regex: (.*):.*
        target_label: __address__
        replacement: $1:9121
