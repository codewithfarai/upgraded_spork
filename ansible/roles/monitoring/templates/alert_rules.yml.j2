groups:
- name: node_alerts
  rules:
  - alert: NodeDown
    expr: up == 0
    for: 1m
    labels:
      severity: critical
    annotations:
      summary: "❌ Node {% raw %}{{ $labels.instance }}{% endraw %} down"
      description: "Node {% raw %}{{ $labels.instance }}{% endraw %} has been down for more than 1 minute."

  - alert: HostHighCpuLoad
    expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[2m])) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "🔥 High CPU load on {% raw %}{{ $labels.instance }}{% endraw %}"
      description: "CPU load is > 80% for more than 5 minutes."

  - alert: HostOutOfMemory
    expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100 < 10
    for: 1m
    labels:
      severity: warning
    annotations:
      summary: "💾 Out of memory on {% raw %}{{ $labels.instance }}{% endraw %}"
      description: "Memory availability is < 10% for more than 1 minute."

  - alert: HostDiskWillFillIn24Hours
    expr: predict_linear(node_filesystem_free_bytes{mountpoint="/"}[4h], 24 * 3600) < 0
    for: 30m
    labels:
      severity: critical
    annotations:
      summary: "📂 Disk will fill in 24 hours on {% raw %}{{ $labels.instance }}{% endraw %}"
      description: "Based on recent usage, disk will be full in 24 hours."

  - alert: HighContainerRestarts
    expr: changes(container_last_seen{container_label_com_docker_swarm_service_name!=""}[5m]) > 2
    for: 1m
    labels:
      severity: warning
    annotations:
      summary: "🚨 High restart rate for {% raw %}{{ $labels.container_label_com_docker_swarm_service_name }}{% endraw %}"
      description: "Service {% raw %}{{ $labels.container_label_com_docker_swarm_service_name }}{% endraw %} on node {% raw %}{{ $labels.instance }}{% endraw %} has restarted frequently in the last 5 minutes."

  - alert: SuspiciousNetworkTraffic
    expr: sum(rate(node_network_receive_packets_total[30s])) by (instance) > 1000
    for: 15s
    labels:
      severity: warning
    annotations:
      summary: "🌐 Suspicious network traffic spike on {% raw %}{{ $labels.instance }}{% endraw %}"
      description: "Incoming packet rate is unusually high (> 1k packets/s)."
