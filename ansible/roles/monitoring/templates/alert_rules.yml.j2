groups:
- name: node_alerts
  rules:
  - alert: NodeDown
    expr: up == 0
    for: 2m
    labels:
      severity: critical
    annotations:
      summary: "Node {% raw %}{{ $labels.instance }}{% endraw %} down"
      description: "Node {% raw %}{{ $labels.instance }}{% endraw %} has been down for more than 2 minutes."

  - alert: HostHighCpuLoad
    expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[2m])) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "High CPU load on {% raw %}{{ $labels.instance }}{% endraw %}"
      description: "CPU load is > 80% for more than 5 minutes."

  - alert: HostOutOfMemory
    expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100 < 10
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: "Out of memory on {% raw %}{{ $labels.instance }}{% endraw %}"
      description: "Memory availability is < 10% for more than 2 minutes."

  - alert: HostDiskWillFillIn24Hours
    expr: predict_linear(node_filesystem_free_bytes{mountpoint="/"}[4h], 24 * 3600) < 0
    for: 30m
    labels:
      severity: critical
    annotations:
      summary: "Disk will fill in 24 hours on {% raw %}{{ $labels.instance }}{% endraw %}"
      description: "Based on recent usage, disk will be full in 24 hours."
  - alert: HighContainerRestarts
    expr: count(changes(container_last_seen{container_label_com_docker_swarm_service_name!=""}[15m]) > 2) > 0
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "High container restart rate"
      description: "One or more containers are restarting frequently in the last 15 minutes."

  - alert: SuspiciousNetworkTraffic
    expr: sum(rate(node_network_receive_packets_total[5m])) by (instance) > 10000
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: "Suspicious network traffic spike on {% raw %}{{ $labels.instance }}{% endraw %}"
      description: "Incoming packet rate is unusually high (> 10k packets/s)."
