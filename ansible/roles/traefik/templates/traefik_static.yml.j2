ping:
  entryPoint: web

api:
  dashboard: true
  debug: true
  insecure: false

entryPoints:
  web:
    address: ":80"
    forwardedHeaders:
      insecure: true # Trust headers from the Hetzner LB
  websecure:
    address: ":443"
    # Even though LB forwards to 80, keeping 443 for internal/direct access if needed
    forwardedHeaders:
      insecure: true
  traefik:
    address: ":8080"
  metrics:
    address: ":8082"

providers:
  swarm:
    endpoint: "tcp://socket-proxy:2375"
    exposedByDefault: false
    watch: true
  file:
    directory: /etc/traefik/dynamic
    watch: true

# ACME is now handled by the Hetzner Load Balancer
# certificatesResolvers section removed

metrics:
  prometheus:
    addEntryPointsLabels: true
    addServicesLabels: true
    entryPoint: metrics

log:
  level: INFO
  format: json

accessLog:
  format: json
  bufferingSize: 100
  fields:
    defaultMode: keep
    names:
      ClientUsername: drop
    headers:
      defaultMode: drop
      names:
        User-Agent: keep
        Authorization: drop
        Content-Type: keep
