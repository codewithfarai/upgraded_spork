ping:
  entryPoint: web

api:
  dashboard: true
  debug: false
  insecure: false

entryPoints:
  web:
    address: ":80"
    http:
      middlewares:
        - global-ratelimit@file
        - security-headers@file
    forwardedHeaders:
      trustedIPs:
        - "10.0.1.5/32"  # Only trust headers from the Hetzner Load Balancer

providers:
  swarm:
    endpoint: "tcp://traefik_socket-proxy:2375"
    exposedByDefault: false
    watch: true
  file:
    directory: /etc/traefik/dynamic
    watch: true

# ACME is now handled by the Hetzner Load Balancer
# certificatesResolvers section removed

metrics:
  prometheus:
    addEntryPointsLabels: true
    addServicesLabels: true
    entryPoint: web

log:
  level: INFO
  format: json

accessLog:
  format: json
  bufferingSize: 100
  fields:
    defaultMode: keep
    names:
      ClientUsername: drop
    headers:
      defaultMode: drop
      names:
        User-Agent: keep
        Authorization: drop
        Content-Type: keep
