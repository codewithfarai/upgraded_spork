version: '3.8'

services:
  socket-proxy:
    image: lscr.io/linuxserver/socket-proxy:latest
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      CONTAINERS: 1
      SERVICES: 1
      TASKS: 1
      NETWORKS: 1
      NODES: 1
      INFO: 1
      SWARM: 1
      EVENTS: 1
      VERSION: 1
      PING: 1
      VOLUMES: 0
      IMAGES: 0
    networks:
      - socket-proxy
    deploy:
      mode: replicated
      replicas: 1
      placement:
        constraints:
          - node.role == manager
      restart_policy:
        condition: on-failure
        delay: 5s
        max_attempts: 3
      resources:
        limits:
          memory: 128M
          cpus: '0.25'
        reservations:
          memory: 64M
          cpus: '0.1'
      update_config:
        parallelism: 1
        delay: 10s
        failure_action: rollback
        monitor: 30s
      rollback_config:
        parallelism: 1
        delay: 5s
        monitor: 30s

  traefik:
    image: traefik:{{ traefik_version | default('v3.6.5') }}
    user: "1000:1000"
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    command:
      - --configFile=/etc/traefik/traefik.yml
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    ports:
      - target: 80
        published: 80
        protocol: tcp
        mode: host
    environment:
      - DOCKER_API_VERSION=1.44
      - "CONFIG_HASH={{ traefik_dynamic_config_hash }}-{{ traefik_static_config_hash }}"
    configs:
      - source: traefik_static-{{ traefik_static_config_hash }}
        target: /etc/traefik/traefik.yml
      - source: traefik_dynamic-{{ traefik_dynamic_config_hash }}
        target: /etc/traefik/dynamic/dynamic.yml
    volumes:
      - traefik-logs:/var/log/traefik:rw
    networks:
      - traefik-public
      - socket-proxy
    deploy:
      mode: global
      placement:
        constraints:
          - node.labels.role == edge
      update_config:
        parallelism: 1
        delay: 10s
        failure_action: rollback
        monitor: 30s
        order: stop-first
      restart_policy:
        condition: on-failure
        delay: 5s
        max_attempts: 3
      rollback_config:
        parallelism: 1
        delay: 5s
        monitor: 30s
      resources:
        limits:
          cpus: '1.5'
          memory: 1536M
        reservations:
          cpus: '0.5'
          memory: 512M
      labels:
        - traefik.enable=true
        - traefik.http.routers.api.rule=Host(`{{ traefik_domain }}`)
        - traefik.http.routers.api.service=api@internal
        - traefik.http.routers.api.entrypoints=web
        - traefik.http.routers.api.middlewares=security-headers@file,authentik-forwardauth@file
        - traefik.http.services.dummy-svc.loadbalancer.server.port=9999
        - traefik.swarm.network=traefik-public

volumes:
  traefik-logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /opt/docker/stacks/traefik/logs

networks:
  traefik-public:
    external: true
  socket-proxy:
    driver: overlay
    internal: true
    driver_opts:
      encrypted: "true"

configs:
  traefik_static-{{ traefik_static_config_hash }}:
    file: /opt/docker/stacks/traefik/traefik.yml
  traefik_dynamic-{{ traefik_dynamic_config_hash }}:
    file: /opt/docker/stacks/traefik/dynamic.yml
