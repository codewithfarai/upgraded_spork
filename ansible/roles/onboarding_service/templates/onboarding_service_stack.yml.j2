version: '3.8'

services:
  onboarding_service:
    image: {{ onboarding_service_image }}:{{ onboarding_service_version }}
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    environment:
      # Authentik OIDC (JWT validation)
      AUTHENTIK_JWKS_URL: "https://{{ authentik_full_domain }}/application/o/ridebase/jwks/"
      AUTHENTIK_ISSUER: "https://{{ authentik_full_domain }}/application/o/ridebase/"
      AUTHENTIK_AUDIENCE: "ridebase"

      # RabbitMQ (via shared-backend overlay load balancer)
      RABBITMQ_URL: "amqp://admin:{{ effective_rabbitmq_password }}@db_ha_pgpool:5672/"
      RABBITMQ_EXCHANGE: "ridebase.events"

      # Redis (OTP storage, via HAProxy on db_ha_pgpool)
      REDIS_URL: "redis://:{{ effective_redis_password }}@db_ha_pgpool:6379/0"

      # Database Connection mapping format: postgresql+asyncpg://user:pass@host:port/dbname
      DATABASE_URL: "postgresql+asyncpg://{{ onboarding_service_db_user }}:{{ effective_onboarding_db_password }}@db_ha_pgpool:5432/{{ onboarding_service_db_name }}?ssl=require"

      # Authentik API (sync group membership)
      AUTHENTIK_API_URL: "https://{{ authentik_full_domain }}"

      # S3 details (Secret key is passed via Secrets)
      S3_ENDPOINT_URL: "{{ onboarding_service_s3_endpoint_url }}"
      S3_ACCESS_KEY: "{{ onboarding_service_s3_access_key }}"
      S3_BUCKET_NAME: "{{ onboarding_service_s3_bucket_name }}"
      S3_REGION_NAME: "{{ onboarding_service_s3_region_name }}"

      # Secrets are read automatically by pydantic-settings from /run/secrets/
    networks:
      - traefik-public
      - shared-backend
    secrets:
      - source: authentik_api_token-{{ authentik_api_token_hash }}
        target: authentik_api_token
      - source: s3_secret_key-{{ s3_secret_key_hash }}
        target: s3_secret_key
      - source: onboarding_db_password-{{ onboarding_db_password_hash }}
        target: onboarding_db_password
      - source: resend_api_key-{{ resend_api_key_hash }}
        target: resend_api_key
    deploy:
      mode: replicated
      replicas: {{ onboarding_service_replicas | default(2) }}
      placement:
        constraints:
          - node.labels.role == worker
        preferences:
          - spread: node.id
      labels:
        - traefik.enable=true
        - traefik.http.routers.onboarding.rule=Host(`{{ onboarding_service_full_domain }}`)
        - traefik.http.routers.onboarding.entrypoints=web
        - traefik.http.routers.onboarding.service=onboarding_service
        - traefik.http.routers.onboarding.middlewares=security-headers@file,global-ratelimit@file
        - traefik.http.services.onboarding_service.loadbalancer.server.port=8000
        - traefik.swarm.network=traefik-public
      update_config:
        parallelism: 1
        delay: 30s
        failure_action: rollback
        order: start-first
      rollback_config:
        parallelism: 1
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.25'
          memory: 128M

networks:
  traefik-public:
    external: true
  shared-backend:
    external: true

secrets:
  authentik_api_token-{{ authentik_api_token_hash }}:
    file: /opt/docker/stacks/onboarding_service/secrets/authentik_api_token

  s3_secret_key-{{ s3_secret_key_hash }}:
    file: /opt/docker/stacks/onboarding_service/secrets/s3_secret_key

  onboarding_db_password-{{ onboarding_db_password_hash }}:
    file: /opt/docker/stacks/onboarding_service/secrets/onboarding_db_password

  resend_api_key-{{ resend_api_key_hash }}:
    file: /opt/docker/stacks/onboarding_service/secrets/resend_api_key
