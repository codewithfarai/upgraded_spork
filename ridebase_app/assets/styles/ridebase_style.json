{
  "version": 8,
  "name": "RideBase",
  "glyphs": "https://fonts.openmaptiles.org/{fontstack}/{range}.pbf",
  "sprite": "https://openmaptiles.github.io/osm-bright-gl-style/sprite",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.dev.ridebase.tech/zimbabwe"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f8f4f0" }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": { "fill-color": "#d8e8c8", "fill-opacity": 0.6 }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": { "fill-color": "#aed1a0", "fill-opacity": 0.5 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#d8e8c8", "fill-opacity": 0.7 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#a0c8f0" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": { "line-color": "#a0c8f0", "line-width": 1.5 }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#d9d0c9",
        "fill-opacity": 0.7,
        "fill-outline-color": "#c9c0b9"
      }
    },
    {
      "id": "tunnel",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "brunnel", "tunnel"],
      "paint": {
        "line-color": "#e9e7e4",
        "line-width": { "base": 1.2, "stops": [[13, 1.5], [20, 18]] },
        "line-dasharray": [0.28, 0.14]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["in", "class", "minor", "service", "track"]
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": { "base": 1.2, "stops": [[13, 1], [17, 6]] }
      }
    },
    {
      "id": "road-secondary-tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["in", "class", "secondary", "tertiary"]
      ],
      "paint": {
        "line-color": "#fefefe",
        "line-width": { "base": 1.2, "stops": [[10, 0.8], [17, 12]] }
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["==", "class", "primary"]
      ],
      "paint": {
        "line-color": "#fce94f",
        "line-width": { "base": 1.2, "stops": [[10, 1], [17, 14]] },
        "line-opacity": 0.5
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["==", "class", "trunk"]
      ],
      "paint": {
        "line-color": "#fbb03b",
        "line-width": { "base": 1.2, "stops": [[8, 1], [17, 16]] },
        "line-opacity": 0.6
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["==", "class", "motorway"]
      ],
      "paint": {
        "line-color": "#e66e00",
        "line-width": { "base": 1.2, "stops": [[6, 0.5], [17, 18]] },
        "line-opacity": 0.6
      }
    },
    {
      "id": "road-name-minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "minor", "service", "track"],
      "minzoom": 15,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 10,
        "symbol-placement": "line"
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "road-name-major",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "primary", "secondary", "tertiary", "trunk", "motorway"],
      "minzoom": 12,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Bold"],
        "text-size": { "stops": [[12, 10], [16, 14]] },
        "symbol-placement": "line"
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "village"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 11,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "town"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Bold"],
        "text-size": { "stops": [[8, 12], [14, 16]] },
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#222222",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "city"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Bold"],
        "text-size": { "stops": [[6, 14], [12, 22]] },
        "text-max-width": 10
      },
      "paint": {
        "text-color": "#111111",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2.5
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 15,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 10,
        "text-max-width": 6,
        "text-offset": [0, 1]
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "water-name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#5d8cc0",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    }
  ]
}
