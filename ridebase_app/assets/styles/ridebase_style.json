{
  "version": 8,
  "name": "RideBase Ultra Minimal",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "tiles": ["https://tiles.ridebase.tech/zimbabwe/{z}/{x}/{y}"],
      "maxzoom": 14
    }
  },
  "glyphs": "https://fonts.openmaptiles.org/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f3f4f6" }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": { "fill-color": "#eef2e7", "fill-opacity": 0.8 }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": { "fill-color": "#e6ede2", "fill-opacity": 0.8 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#e3ebe0", "fill-opacity": 0.8 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#cddae6" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": { "line-color": "#cddae6", "line-width": 1.5 }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#e9eaea",
        "fill-opacity": 0.8,
        "fill-outline-color": "#dcdcdc"
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["in", "class", "minor", "service", "track"]
      ],
      "minzoom": 13,
      "paint": {
        "line-color": "#e6e6e6",
        "line-width": { "base": 1.2, "stops": [[13, 1.5], [17, 8]] }
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["in", "class", "minor", "service", "track"]
      ],
      "minzoom": 13,
      "paint": {
        "line-color": "#ffffff",
        "line-width": { "base": 1.2, "stops": [[13, 0.5], [17, 6]] }
      }
    },
    {
      "id": "road-secondary-tertiary-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["in", "class", "secondary", "tertiary"]
      ],
      "paint": {
        "line-color": "#e1e1e1",
        "line-width": { "base": 1.2, "stops": [[10, 1.2], [17, 15]] }
      }
    },
    {
      "id": "road-secondary-tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["in", "class", "secondary", "tertiary"]
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": { "base": 1.2, "stops": [[10, 0.5], [17, 12]] }
      }
    },
    {
      "id": "road-primary-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["==", "class", "primary"]
      ],
      "paint": {
        "line-color": "#dcdcdc",
        "line-width": { "base": 1.2, "stops": [[10, 2], [17, 18]] }
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["==", "class", "primary"]
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": { "base": 1.2, "stops": [[10, 1.5], [17, 15]] }
      }
    },
    {
      "id": "road-trunk-motorway-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["in", "class", "trunk", "motorway"]
      ],
      "paint": {
        "line-color": "#d6d8db",
        "line-width": { "base": 1.2, "stops": [[6, 1.5], [17, 24]] }
      }
    },
    {
      "id": "road-trunk-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all",
        ["!has", "brunnel"],
        ["in", "class", "trunk", "motorway"]
      ],
      "paint": {
        "line-color": "#fefefe",
        "line-width": { "base": 1.2, "stops": [[6, 1], [17, 20]] }
      }
    },
    {
      "id": "tunnel",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "brunnel", "tunnel"],
      "paint": {
        "line-color": "#f2f4f7",
        "line-width": { "base": 1.2, "stops": [[13, 1.5], [20, 18]] },
        "line-dasharray": [0.3, 0.3]
      }
    },
    {
      "id": "road-name-minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "minor", "service", "track"],
      "minzoom": 16,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 10,
        "symbol-placement": "line"
      },
      "paint": {
        "text-color": "#a8b5c2",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "road-name-major",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "primary", "secondary", "tertiary", "trunk", "motorway"],
      "minzoom": 13,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Bold"],
        "text-size": { "stops": [[13, 10], [16, 14]] },
        "symbol-placement": "line"
      },
      "paint": {
        "text-color": "#818c99",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2.5
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "village"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 12,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#768291",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "town"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Bold"],
        "text-size": { "stops": [[8, 12], [14, 16]] },
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#4a5360",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2.5
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "city"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Bold"],
        "text-size": { "stops": [[6, 14], [12, 22]] },
        "text-max-width": 10
      },
      "paint": {
        "text-color": "#181a1c",
        "text-halo-color": "#ffffff",
        "text-halo-width": 3
      }
    },
    {
      "id": "water-name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#7a9cba",
        "text-halo-color": "#cddae6",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 15,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 11,
        "text-max-width": 8,
        "text-padding": 2
      },
      "paint": {
        "text-color": "#6e7b8a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    }
  ]
}
